# API Configuration
JOKEAPI_URL=https://v2.jokeapi.dev/joke
OFFICIALJOKEAPI_URL=https://official-joke-api.appspot.com
CHUCKNORRIS_URL=https://api.chucknorris.io/jokes
RAPIDAPI_KEY=your_rapid_api_key_here

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_DRIVER=file
CACHE_PATH=storage/cache

# Application
APP_ENV=development
APP_DEBUG=true
APP_NAME=Joke Generator
APP_URL=http://localhost:8001

# Database (optional)
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=3306
DB_NAME=joke_db
DB_USER=root
DB_PASS=

# Logging
LOG_ENABLED=true
LOG_PATH=storage/logs
LOG_LEVEL=info

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# CORS
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8001
